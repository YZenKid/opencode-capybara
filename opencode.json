{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "9router": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "9Router",
      "options": {
        "baseURL": "{env:NINEROUTER_URL}/v1",
        "apiKey": "{env:NINEROUTER_KEY}"
      },
      "models": {
        "high": {
          "id": "high",
          "name": "High",
          "attachment": true,
          "reasoning": true,
          "modalities": {
            "input": [
              "text",
              "image"
            ],
            "output": [
              "text"
            ]
          },
          "limit": {
            "context": 400000,
            "input": 272000,
            "output": 128000
          },
          "variants": {
            "medium": {
              "reasoningEffort": "medium",
              "textVerbosity": "medium",
              "reasoningSummary": "auto"
            },
            "high": {
              "reasoningEffort": "high",
              "textVerbosity": "high",
              "reasoningSummary": "auto"
            },
            "xhigh": {
              "reasoningEffort": "xhigh",
              "textVerbosity": "high",
              "reasoningSummary": "auto"
            },
            "low": {
              "reasoningEffort": "low",
              "textVerbosity": "low",
              "reasoningSummary": "auto"
            }
          }
        },
        "medium": {
          "id": "medium",
          "name": "Medium",
          "attachment": true,
          "reasoning": true,
          "modalities": {
            "input": [
              "text",
              "image"
            ],
            "output": [
              "text"
            ]
          },
          "limit": {
            "context": 400000,
            "input": 272000,
            "output": 128000
          },
          "variants": {
            "medium": {
              "reasoningEffort": "medium",
              "textVerbosity": "medium",
              "reasoningSummary": "auto"
            },
            "high": {
              "reasoningEffort": "high",
              "textVerbosity": "high",
              "reasoningSummary": "auto"
            },
            "xhigh": {
              "reasoningEffort": "xhigh",
              "textVerbosity": "high",
              "reasoningSummary": "auto"
            },
            "low": {
              "reasoningEffort": "low",
              "textVerbosity": "low",
              "reasoningSummary": "auto"
            }
          }
        },
        "low": {
          "id": "low",
          "name": "Low",
          "attachment": true,
          "reasoning": true,
          "modalities": {
            "input": [
              "text"
            ],
            "output": [
              "text"
            ]
          },
          "limit": {
            "context": 400000,
            "input": 272000,
            "output": 128000
          },
          "variants": {
            "medium": {
              "reasoningEffort": "medium",
              "textVerbosity": "medium",
              "reasoningSummary": "auto"
            },
            "high": {
              "reasoningEffort": "high",
              "textVerbosity": "high",
              "reasoningSummary": "auto"
            },
            "xhigh": {
              "reasoningEffort": "xhigh",
              "textVerbosity": "high",
              "reasoningSummary": "auto"
            },
            "low": {
              "reasoningEffort": "low",
              "textVerbosity": "low",
              "reasoningSummary": "auto"
            }
          }
        },
        "fast": {
          "id": "cx/gpt-5.4-mini",
          "name": "Fast",
          "attachment": true,
          "modalities": {
            "input": [
              "text"
            ],
            "output": [
              "text"
            ]
          },
          "limit": {
            "context": 200000,
            "output": 64000
          }
        },
        "vision": {
          "id": "vision",
          "name": "Vision",
          "attachment": true,
          "modalities": {
            "input": [
              "text",
              "image"
            ],
            "output": [
              "text"
            ]
          },
          "limit": {
            "context": 200000,
            "output": 64000
          }
        }
      }
    }
  },
  "model": "{env:OPENCODE_MODEL_DEFAULT}",
  "default_agent": "orchestrator",
  "mcp": {
    "time": {
      "type": "local",
      "command": [
        "uvx",
        "mcp-server-time"
      ]
    },
    "9router": {
      "type": "local",
      "command": [
        "node",
        "{env:HOME}/.config/opencode/bin/9router-mcp.mjs"
      ],
      "environment": {
        "NINEROUTER_URL": "{env:NINEROUTER_URL}",
        "NINEROUTER_KEY": "{env:NINEROUTER_KEY}",
        "NINEROUTER_SEARCH_MODEL": "{env:NINEROUTER_SEARCH_MODEL}",
        "NINEROUTER_FETCH_MODEL": "{env:NINEROUTER_FETCH_MODEL}",
        "NINEROUTER_IMAGE_MODEL": "{env:NINEROUTER_IMAGE_MODEL}",
        "NINEROUTER_IMAGE_DEFAULT_SIZE": "{env:NINEROUTER_IMAGE_DEFAULT_SIZE}",
        "NINEROUTER_IMAGE_DEFAULT_QUALITY": "{env:NINEROUTER_IMAGE_DEFAULT_QUALITY}",
        "NINEROUTER_IMAGE_DEFAULT_BACKGROUND": "{env:NINEROUTER_IMAGE_DEFAULT_BACKGROUND}",
        "NINEROUTER_IMAGE_MAX_BYTES": "{env:NINEROUTER_IMAGE_MAX_BYTES}"
      },
      "enabled": true,
      "timeout": 300000
    },
    "context7": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@upstash/context7-mcp",
        "--api-key",
        "{env:CONTEXT7_API_KEY}"
      ],
      "timeout": 180000,
      "enabled": true
    },
    "sequential-thinking": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-sequential-thinking"
      ],
      "environment": {
        "DISABLE_THOUGHT_LOGGING": "true"
      },
      "enabled": true,
      "timeout": 30000
    },
    "grep_app": {
      "type": "remote",
      "url": "https://mcp.grep.app",
      "enabled": true
    },
    "playwright": {
      "type": "local",
      "command": [
        "bash",
        "-lc",
        "\"$HOME/.config/opencode/bin/playwright-chrome-cdp\" >/tmp/playwright-cdp-bootstrap.log 2>&1 && exec npx @playwright/mcp@latest --cdp-endpoint=http://127.0.0.1:9333"
      ],
      "enabled": true,
      "timeout": 180000
    },
    "shadcn": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "shadcn@latest",
        "mcp"
      ],
      "enabled": true,
      "timeout": 120000
    },
    "semgrep": {
      "type": "local",
      "command": [
        "uvx",
        "semgrep",
        "mcp",
        "-t",
        "stdio"
      ],
      "enabled": true,
      "timeout": 120000
    },
    "github": {
      "type": "remote",
      "url": "https://api.githubcopilot.com/mcp/",
      "headers": {
        "Authorization": "Bearer {env:GITHUB_PERSONAL_ACCESS_TOKEN}",
        "X-MCP-Toolsets": "{env:GITHUB_TOOLSETS}"
      },
      "oauth": false,
      "enabled": true,
      "timeout": 30000
    },
    "postgres_local": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-postgres",
        "{env:LOCAL_POSTGRES_URL}"
      ],
      "enabled": false,
      "timeout": 30000
    },
    "git_local": {
      "type": "local",
      "command": [
        "uvx",
        "mcp-server-git",
        "--repository",
        "."
      ],
      "enabled": false,
      "timeout": 30000
    },
    "sqlite_local": {
      "type": "local",
      "command": [
        "uvx",
        "mcp-server-sqlite",
        "--db-path",
        "{env:LOCAL_SQLITE_PATH}"
      ],
      "enabled": false,
      "timeout": 30000
    }
  },
  "agent": {
    "council": {
      "mode": "subagent"
    },
    "build": {
      "disable": true
    },
    "plan": {
      "disable": true
    },
    "explore": {
      "disable": true
    },
    "general": {
      "disable": true
    }
  },
  "lsp": true
}
