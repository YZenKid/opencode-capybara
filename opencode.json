{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "cliproxyapi": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "CliProxyAPI",
      "options": {
        "baseURL": "{env:CLIPROXYAPI_BASE_URL}",
        "apiKey": "{env:CLIPROXYAPI_API_KEY}"
      },
      "models": {
        "high": {
          "name": "High",
          "attachment": true,
          "modalities": {
            "input": [
              "text",
              "image"
            ],
            "output": [
              "text"
            ]
          },
          "limit": {
            "context": 400000,
            "input": 272000,
            "output": 128000
          },
          "variants": {
            "medium": {
              "reasoningEffort": "medium",
              "textVerbosity": "medium",
              "reasoningSummary": "auto"
            },
            "high": {
              "reasoningEffort": "high",
              "textVerbosity": "high",
              "reasoningSummary": "auto"
            },
            "xhigh": {
              "reasoningEffort": "xhigh",
              "textVerbosity": "high",
              "reasoningSummary": "auto"
            },
            "low": {
              "reasoningEffort": "low",
              "textVerbosity": "low",
              "reasoningSummary": "auto"
            }
          }
        },
        "low": {
          "name": "Low",
          "attachment": true,
          "modalities": {
            "input": [
              "text",
              "image"
            ],
            "output": [
              "text"
            ]
          },
          "limit": {
            "context": 400000,
            "input": 272000,
            "output": 128000
          },
          "variants": {
            "medium": {
              "reasoningEffort": "medium",
              "textVerbosity": "medium",
              "reasoningSummary": "auto"
            },
            "high": {
              "reasoningEffort": "high",
              "textVerbosity": "high",
              "reasoningSummary": "auto"
            },
            "xhigh": {
              "reasoningEffort": "xhigh",
              "textVerbosity": "high",
              "reasoningSummary": "auto"
            },
            "low": {
              "reasoningEffort": "low",
              "textVerbosity": "low",
              "reasoningSummary": "auto"
            }
          }
        },
        "medium": {
          "name": "Medium",
          "attachment": true,
          "modalities": {
            "input": [
              "text",
              "image"
            ],
            "output": [
              "text"
            ]
          },
          "limit": {
            "context": 400000,
            "input": 272000,
            "output": 128000
          },
          "variants": {
            "medium": {
              "reasoningEffort": "medium",
              "textVerbosity": "medium",
              "reasoningSummary": "auto"
            },
            "high": {
              "reasoningEffort": "high",
              "textVerbosity": "high",
              "reasoningSummary": "auto"
            },
            "xhigh": {
              "reasoningEffort": "xhigh",
              "textVerbosity": "high",
              "reasoningSummary": "auto"
            },
            "low": {
              "reasoningEffort": "low",
              "textVerbosity": "low",
              "reasoningSummary": "auto"
            }
          }
        },
        "cx/gpt-5.5-image": {
          "name": "CX GPT 5.5 Image",
          "attachment": true,
          "modalities": {
            "input": [
              "text",
              "image"
            ],
            "output": [
              "image"
            ]
          },
          "variants": {
            "low": {
              "quality": "low"
            },
            "medium": {
              "quality": "medium"
            },
            "high": {
              "quality": "high"
            }
          }
        }
      }
    }
  },
  "model": "{env:OPENCODE_MODEL_DEFAULT}",
  "default_agent": "orchestrator",
  "mcp": {
    "time": {
      "type": "local",
      "command": [
        "uvx",
        "mcp-server-time"
      ]
    },
    "brave-search": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-brave-search"
      ],
      "environment": {
        "BRAVE_API_KEY": "{env:BRAVE_API_KEY}"
      }
    },
    "context7": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@upstash/context7-mcp",
        "--api-key",
        "{env:CONTEXT7_API_KEY}"
      ]
    },
    "grep_app": {
      "type": "remote",
      "url": "https://mcp.grep.app",
      "enabled": true
    },
    "playwright": {
      "type": "local",
      "command": [
        "npx",
        "@playwright/mcp@latest",
        "--cdp-endpoint=http://127.0.0.1:9333"
      ],
      "enabled": true,
      "timeout": 30000
    },
    "shadcn": {
      "type": "local",
      "command": [
        "npx",
        "shadcn@latest",
        "mcp"
      ],
      "enabled": true,
      "timeout": 30000
    },
    "image-asset-generator": {
      "type": "local",
      "command": [
        "node",
        "{env:HOME}/.config/opencode/bin/image-asset-mcp.mjs"
      ],
      "environment": {
        "IMAGE_ASSET_BASE_URL": "{env:CLIPROXYAPI_BASE_URL}",
        "IMAGE_ASSET_API_KEY": "{env:CLIPROXYAPI_API_KEY}",
        "IMAGE_ASSET_MODEL": "{env:IMAGE_ASSET_MODEL}"
      },
      "enabled": true,
      "timeout": 300000
    },
    "semgrep": {
      "type": "local",
      "command": [
        "uvx",
        "semgrep",
        "mcp",
        "-t",
        "stdio"
      ],
      "enabled": true,
      "timeout": 120000
    },
    "github": {
      "type": "remote",
      "url": "https://api.githubcopilot.com/mcp/",
      "headers": {
        "Authorization": "Bearer {env:GITHUB_PERSONAL_ACCESS_TOKEN}",
        "X-MCP-Toolsets": "{env:GITHUB_TOOLSETS}"
      },
      "oauth": false,
      "enabled": true,
      "timeout": 30000
    }
  },
  "agent": {
    "council": {
      "mode": "subagent"
    },
    "build": {
      "disable": true
    },
    "plan": {
      "disable": true
    },
    "explore": {
      "disable": true
    },
    "general": {
      "disable": true
    }
  },
  "lsp": true
}
