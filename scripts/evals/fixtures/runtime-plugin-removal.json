{
  "id": "runtime-plugin-removal",
  "description": "Validates that the standalone harness no longer depends on the removed upstream preset path.",
  "rules": [
    {
      "file": "package.json",
      "mustNotInclude": [
        "oh-my-opencode-slim"
      ],
      "reasonCode": "runtime-plugin-regression"
    },
    {
      "file": "opencode.json",
      "mustNotInclude": [
        "oh-my-opencode-slim"
      ],
      "reasonCode": "runtime-config-regression"
    }
  ]
}
