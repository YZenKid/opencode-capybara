{
  "name": "opencode-capybara",
  "private": true,
  "scripts": {
    "docs:generate": "node scripts/generate-generated-docs.mjs",
    "docs:generate:check": "node scripts/generate-generated-docs.mjs --check",
    "sync:agent-models": "node scripts/sync-agent-models.mjs",
    "sync:agent-models:check": "node scripts/sync-agent-models.mjs --check",
    "setup:tools": "node scripts/setup-dev-tools.mjs",
    "setup:tools:check": "node scripts/setup-dev-tools.mjs --check",
    "doctor": "node scripts/doctor.mjs",
    "post:update": "node scripts/post-update-refresh.mjs",
    "check:docs": "node scripts/docs-integrity-check.mjs",
    "check:agents": "node scripts/agent-boundary-check.mjs",
    "check:skills": "node scripts/skill-contract-check.mjs",
    "check:evidence": "node scripts/evidence-contract-check.mjs",
    "check:harness": "npm run test:prompt-gates && npm run check:docs && npm run check:agents && npm run check:skills && npm run check:evidence",
    "check:harness:strict": "npm run check:harness && npm run eval:harness",
    "check:routing-release": "node scripts/evals/release-gate-check.mjs",
    "check:release": "npm run check:harness:strict && npm run check:routing-release && npm run doctor",
    "eval:harness": "node scripts/evals/harness-eval-runner.mjs",
    "test:prompt-gates": "node scripts/prompt-gate-regression.mjs",
    "sync:openchamber": "node scripts/sync-openchamber-settings.mjs",
    "sync:openchamber:check": "node scripts/sync-openchamber-settings.mjs --check",
    "sync:openchamber:seed": "node scripts/sync-openchamber-settings.mjs --seed-approved-directories",
    "sync:openchamber:seed:check": "node scripts/sync-openchamber-settings.mjs --check --seed-approved-directories"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@opencode-ai/plugin": "1.14.48",
    "openai": "^6.35.0",
    "sharp": "^0.34.5",
    "zod": "^4.4.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.4",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.4",
    "postcss": "^8.5.13",
    "tailwindcss": "^4.2.4",
    "typescript": "^6.0.3"
  }
}
